<div id="articlesRight">
    {{#each articles}}
    <div class="article row">
        <div class="col s10">
            <a href="{{url}}" target="_blank">{{title}}</a>
            <p>{{parsePublishedAtDate publishedAt}}</p>
        </div>
    </div>
    <div class="divider"></div>
    {{/each}}
</div>