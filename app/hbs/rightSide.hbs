<div id="articlesRight">
    {{#each articles}}
    <div class="article row">
        <div class="col s2 valign-wrapper">
            <img class="website-icon" src="//logo.clearbit.com/{{extractDomain url}}">
        </div>
        <div class="col s10">
            <a href="{{url}}">{{title}}</a>
            <p>{{parsePublishetAtDate publishedAt}}</p>
        </div>
    </div>
    <div class="divider"></div>
    {{/each}}
</div>