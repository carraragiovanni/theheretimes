<div id="log-in-sign-up-window" class="forms">
    <ul class="tab-group">
        <li id="log-in-tab" class="tab"><a data-id="login">Log In</a></li>
        <li id="sign-up-tab" class="tab active"><a data-id="signup">Sign Up</a></li>
    </ul>
    <div id="log-in-window">
        <form action="#" id="login">
            <div class="credentials-input-field">
                <label for="email">Email</label>
                <input id="emailLogIn" type="email" name="email" required="email"  autocomplete="email username"/>
                <label for="password">Password</label>
                <input id="passwordLogIn" type="password" name="password" autocomplete="current-password" required/>
                <input id="logIn" type="button" value="Login" class="button" />
                <p class="text-p"> <a href="#">Forgot password?</a> </p>
            </div>
        </form>
    </div>
    <div id="sign-up-window">
        <form action="#" id="signup">
            <div class="credentials-input-field">
                <label for="email">Email</label>
                <input id="emailSignUp" type="email" name="email" required="email" autocomplete="email username"/>
                <label for="password">Password</label>
                <input id="passwordSignUp" type="password" name="password" autocomplete="new-password" required />
                <label for="password">Confirm Password</label>
                <input type="password" name="password" autocomplete="new-password" required />
                <input id="signUp" type="button" value="Sign up" class="button"/>
            </div>
        </form>
    </div>
</div>